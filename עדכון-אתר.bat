@echo off
chcp 65001 >nul
cd /d "%~dp0"
echo ============================================
echo        מעלה את השינויים לגיטהאב...
echo ============================================
echo.
set /p msg="תארי בקצרה מה שינית (או לחצי Enter לדלג): "
if "%msg%"=="" set msg=update
git add -A
git commit -m "%msg%"
git push
echo.
echo ============================================
echo        סיימתי! השינויים עלו לגיטהאב.
echo ============================================
echo.
pause
